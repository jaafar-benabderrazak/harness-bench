# Backend: "ollama" (default, free, local) or "anthropic" (paid API)
HARNESS_BACKEND=ollama

# Model id for the active backend.
# ollama:    mistral:7b | llama3.1:70b | mixtral:8x7b | phi3:mini | ...
# anthropic: claude-sonnet-4-6 | claude-haiku-4-5 | claude-opus-4-7
HARNESS_MODEL=mistral:7b

HARNESS_MAX_TOKENS=2048
HARNESS_TEMPERATURE=0.0

# Only needed when HARNESS_BACKEND=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
